---
import Layout from '../../layouts/Layout.astro';
import App from '../../components/App';
import { createClient } from '@supabase/supabase-js';
import { MOCK_PRODUCTS } from '../../lib/mockData';

export async function getStaticPaths() {
  const supabase = createClient(
    import.meta.env.PUBLIC_SUPABASE_URL || 'http://localhost:54321',
    import.meta.env.PUBLIC_SUPABASE_ANON_KEY || 'dummy'
  );
  
  let ids: string[] = [];
  try {
    const { data } = await supabase.from('products').select('id');
    ids = (data ?? []).map((p: { id: string }) => p.id);
  } catch (e) {
    // Silent catch for build
  }

  const mockIds = MOCK_PRODUCTS.map(p => p.id);
  const allIds = [...new Set([...ids, ...mockIds])];
  if (allIds.length === 0) allIds.push('placeholder');
  
  return allIds.map((id) => ({ params: { id } }));
}

const { id } = Astro.params;
---
<Layout title="Producto">
  <App client:only="react" currentPath="/products" productId={id} />
</Layout>
