---
export interface Props {
  title?: string;
  description?: string;
}
const { title = "Tienda Online", description = "Tu tienda favorita" } =
  Astro.props;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap"
      rel="stylesheet"
    />
    <title>{title} | Tienda Online</title>
    <script is:inline>
      const theme = (() => {
        if (
          typeof localStorage !== "undefined" &&
          localStorage.getItem("theme")
        ) {
          return localStorage.getItem("theme");
        }
        if (window.matchMedia("(prefers-color-scheme: dark)").matches) {
          return "dark";
        }
        return "light";
      })();
      document.documentElement.setAttribute("data-theme", theme);
    </script>
  </head>
  <body>
    <slot />
  </body>
</html>

<style is:global>
  *,
  *::before,
  *::after {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
  }

  :root {
    /* Dark Theme (Default) */
    --color-bg: #0a0a0f;
    --color-surface: #12121a;
    --color-surface2: #1a1a28;
    --color-border: rgba(255, 255, 255, 0.08);
    --color-text: #e8e8f0;
    --color-text-muted: #8888a8;
    --color-primary: #7c6bff;
    --color-primary-hover: #9180ff;
    --color-accent: #ff6b9d;
    --color-success: #4ade80;
    --color-warning: #fbbf24;
    --color-danger: #f87171;
    --color-nav-bg: rgba(10, 10, 15, 0.85);
    --color-glass: rgba(255, 255, 255, 0.03);
    --color-glass-border: rgba(255, 255, 255, 0.08);
    --color-input-bg: rgba(0, 0, 0, 0.2);
    --radius: 12px;
    --radius-sm: 8px;
    --shadow: 0 4px 24px rgba(0, 0, 0, 0.4);
    --transition: 0.2s ease;
  }

  :root[data-theme="light"] {
    --color-bg: #f8f9fa;
    --color-surface: #ffffff;
    --color-surface2: #f1f3f5;
    --color-border: rgba(0, 0, 0, 0.08);
    --color-text: #1a1a21;
    --color-text-muted: #5f6368;
    --color-primary: #6355ff;
    --color-primary-hover: #5046e5;
    --color-nav-bg: rgba(255, 255, 255, 0.85);
    --color-glass: rgba(0, 0, 0, 0.02);
    --color-glass-border: rgba(0, 0, 0, 0.05);
    --color-input-bg: #ffffff;
    --shadow: 0 4px 20px rgba(0, 0, 0, 0.06);
  }

  body {
    background: var(--color-bg);
    color: var(--color-text);
    font-family: "Inter", system-ui, sans-serif;
    font-size: 15px;
    line-height: 1.6;
    min-height: 100vh;
  }

  a {
    color: inherit;
    text-decoration: none;
  }
  img {
    max-width: 100%;
    display: block;
  }

  button {
    cursor: pointer;
    font-family: inherit;
    font-size: 14px;
    border: none;
    outline: none;
    transition: all var(--transition);
  }

  input,
  textarea,
  select {
    font-family: inherit;
    font-size: 14px;
    color: var(--color-text);
    background: var(--color-surface2);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    padding: 10px 14px;
    width: 100%;
    transition: border-color var(--transition);
    outline: none;
  }
  input:focus,
  textarea:focus,
  select:focus {
    border-color: var(--color-primary);
  }

  .btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    padding: 10px 20px;
    border-radius: var(--radius-sm);
    font-weight: 600;
    transition: all var(--transition);
    cursor: pointer;
  }
  .btn-primary {
    background: var(--color-primary);
    color: #fff;
    border: none;
  }
  .btn-primary:hover {
    background: var(--color-primary-hover);
    transform: translateY(-1px);
    box-shadow: 0 4px 16px rgba(124, 107, 255, 0.4);
  }
  .btn-ghost {
    background: transparent;
    color: var(--color-text);
    border: 1px solid var(--color-border);
  }
  .btn-ghost:hover {
    border-color: var(--color-primary);
    color: var(--color-primary);
  }
  .btn-danger {
    background: var(--color-danger);
    color: #fff;
    border: none;
  }
  .btn-danger:hover {
    opacity: 0.85;
  }
  .btn-sm {
    padding: 6px 14px;
    font-size: 13px;
  }

  .card {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    overflow: hidden;
    transition:
      transform var(--transition),
      box-shadow var(--transition);
  }
  .card:hover {
    transform: translateY(-2px);
    box-shadow: var(--shadow);
  }

  .badge {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    padding: 2px 8px;
    border-radius: 100px;
    font-size: 12px;
    font-weight: 600;
  }
  .badge-primary {
    background: rgba(124, 107, 255, 0.15);
    color: var(--color-primary);
  }
  .badge-success {
    background: rgba(74, 222, 128, 0.15);
    color: var(--color-success);
  }
  .badge-warning {
    background: rgba(251, 191, 36, 0.15);
    color: var(--color-warning);
  }
  .badge-danger {
    background: rgba(248, 113, 113, 0.15);
    color: var(--color-danger);
  }

  .container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 24px;
  }

  .toast {
    position: fixed;
    bottom: 24px;
    right: 24px;
    z-index: 9999;
    padding: 14px 20px;
    border-radius: var(--radius-sm);
    font-size: 14px;
    font-weight: 500;
    animation: slideIn 0.3s ease;
    box-shadow: var(--shadow);
  }
  .toast-success {
    background: var(--color-success);
    color: #000;
  }
  .toast-error {
    background: var(--color-danger);
    color: #fff;
  }

  @keyframes slideIn {
    from {
      transform: translateX(120%);
      opacity: 0;
    }
    to {
      transform: translateX(0);
      opacity: 1;
    }
  }

  ::-webkit-scrollbar {
    width: 6px;
  }
  ::-webkit-scrollbar-track {
    background: var(--color-bg);
  }
  ::-webkit-scrollbar-thumb {
    background: var(--color-border);
    border-radius: 3px;
  }
</style>
